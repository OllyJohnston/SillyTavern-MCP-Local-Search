{
  "name": "sillytavern-mcp-local-search",
  "version": "1.4.0",
  "description": "Native SillyTavern extension for high-quality local web search using Playwright.",
  "main": "index.js",
  "type": "module",
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "format": "prettier --write \"src/**/*.{ts,js}\"",
    "lint": "eslint src/server",
    "test": "vitest run",
    "release": "pwsh ./build-release.ps1",
    "prepare": "playwright install chromium",
    "husky:init": "husky"
  },
  "lint-staged": {
    "src/**/*.{ts,js}": [
      "prettier --write"
    ]
  },
  "keywords": [
    "sillytavern-extension",
    "web-search",
    "playwright",
    "mcp"
  ],
  "author": "Olly Johnston",
  "license": "MIT",
  "dependencies": {
    "axios": "^1.6.8",
    "cheerio": "^1.0.0-rc.12",
    "dompurify": "^3.3.3",
    "jsdom": "^29.0.1",
    "p-limit": "^6.2.0",
    "p-retry": "^6.2.1",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "playwright": "^1.48.0",
    "zod": "^3.22.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/dompurify": "^3.0.5",
    "@types/eslint__js": "^8.42.3",
    "@types/express": "^5.0.6",
    "@types/jsdom": "^28.0.1",
    "@types/node": "^24.12.0",
    "@types/p-limit": "^2.1.0",
    "eslint": "^10.1.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.2",
    "typescript": "^5.4.5",
    "typescript-eslint": "^8.58.0",
    "vitest": "^4.1.2"
  }
}
